<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_base"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/tile_binding_description"
        android:textColor="?attr/lightGreyText"
        android:textSize="15sp" />

    <LinearLayout
        android:id="@+id/tile_network_list"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_surface_subtle"
        android:orientation="vertical"
        android:padding="8dp" />

    <TextView
        android:id="@+id/tile_network_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="@string/tile_no_networks"
        android:textAlignment="center"
        android:textColor="?attr/lightGreyText"
        android:visibility="gone" />

    <Button
        android:id="@+id/tile_clear_binding"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="@string/tile_clear_binding" />
</LinearLayout>
