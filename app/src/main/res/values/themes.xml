<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.ZerotierFix" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:statusBarColor" tools:targetApi="l">?attr/colorPrimaryVariant</item>
        <item name="android:navigationBarColor">@color/surface_base</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:windowBackground">@color/surface_base</item>
        <item name="android:fontFamily">sans</item>
        <item name="android:colorAccent">@color/fab_neutral</item>
        <item name="colorControlActivated">@color/fab_neutral</item>
        <item name="materialButtonStyle">@style/Widget.ZerotierFix.Button</item>
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.ZerotierFix.AlertDialog</item>
        <item name="greyText">@color/grey_text</item>
        <item name="lightGreyText">@color/light_grey_text</item>
        <item name="tableRowGrey">@color/table_row_grey</item>
    </style>

    <style name="Theme.ZerotierFix.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Theme.ZerotierFix.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />

    <style name="Theme.ZerotierFix.PopupOverlay" parent="ThemeOverlay.AppCompat.Light" />

    <style name="Widget.ZerotierFix.Button" parent="Widget.MaterialComponents.Button">
        <item name="android:minHeight">48dp</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="ThemeOverlay.ZerotierFix.AlertDialog" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.ZerotierFix.Dialog</item>
    </style>

    <style name="ShapeAppearance.ZerotierFix.Dialog" parent="ShapeAppearance.MaterialComponents.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">20dp</item>
    </style>
</resources>
